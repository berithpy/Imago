{
	"name": "imago",
	"type": "module",
	"scripts": {
		"setup:dev": "node scripts/generate-dev-vars.js",
		"secrets:push": "node scripts/push-prod-secrets.js",
		"reset:admin": "node scripts/reset-admin.js",
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "vite build && wrangler deploy --minify",
		"worker:dev": "wrangler dev",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"db:generate": "drizzle-kit generate",
		"db:reset:local": "node -e \"require('fs').rmSync('.wrangler/state/v3/d1',{recursive:true,force:true})\" && npm run db:migrate:local",
		"db:migrate:local": "wrangler d1 migrations apply imago-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply imago-db --remote",
		"db:create": "wrangler d1 create imago-db",
		"test:routes": "vitest run src/worker/routes/__tests__",
		"test": "vitest run",
		"prepare": "husky"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.9",
		"@vitejs/plugin-react": "^5.1.4",
		"better-auth": "^1.4.19",
		"drizzle-orm": "^0.45.1",
		"fflate": "^0.8.2",
		"hono": "^4.12.2",
		"kysely": "^0.28.11",
		"kysely-d1": "^0.4.0",
		"masonic": "^4.1.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.1",
		"vite": "^7.3.1"
	},
	"devDependencies": {
		"@types/node": "^25.3.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4",
		"wrangler": "^4.68.1"
	},
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
